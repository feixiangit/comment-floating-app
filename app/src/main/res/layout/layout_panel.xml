<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:elevation="16dp"
    android:layout_margin="8dp">

    <!-- 视频标题 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="视频标题"
        android:textSize="12sp"
        android:textColor="#666666"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginBottom="12dp"/>

    <!-- 评论选项 -->
    <Button
        android:id="@+id/btn_comment_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. 评论内容"
        android:textSize="14sp"
        android:padding="12dp"
        android:gravity="start|center_vertical"
        android:backgroundTint="#E3F2FD"
        android:textColor="#1976D2"
        android:layout_marginBottom="4dp"/>

    <Button
        android:id="@+id/btn_comment_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2. 评论内容"
        android:textSize="14sp"
        android:padding="12dp"
        android:gravity="start|center_vertical"
        android:backgroundTint="#E8F5E9"
        android:textColor="#388E3C"
        android:layout_marginBottom="4dp"/>

    <Button
        android:id="@+id/btn_comment_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3. 评论内容"
        android:textSize="14sp"
        android:padding="12dp"
        android:gravity="start|center_vertical"
        android:backgroundTint="#FFF3E0"
        android:textColor="#F57C00"
        android:layout_marginBottom="4dp"/>

    <Button
        android:id="@+id/btn_comment_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="4. 评论内容"
        android:textSize="14sp"
        android:padding="12dp"
        android:gravity="start|center_vertical"
        android:backgroundTint="#F3E5F5"
        android:textColor="#7B1FA2"
        android:layout_marginBottom="4dp"/>

    <Button
        android:id="@+id/btn_comment_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="5. 评论内容"
        android:textSize="14sp"
        android:padding="12dp"
        android:gravity="start|center_vertical"
        android:backgroundTint="#FFEBEE"
        android:textColor="#D32F2F"
        android:layout_marginBottom="8dp"/>

    <!-- 关闭按钮 -->
    <Button
        android:id="@+id/btn_close"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="关闭"
        android:textSize="12sp"
        android:backgroundTint="#9E9E9E"/>

</LinearLayout>
